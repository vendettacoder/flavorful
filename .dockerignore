# Keep the image small and secrets out of it.
.venv
__pycache__/
*.py[oc]
*.egg-info
build/
dist/
wheels/

# Secrets — provided at runtime via `fly secrets set`, never baked into the image.
.env

# Not part of the backend.
flavorful-ios/
PRIVACY_POLICY.md

# VCS / tooling.
.git
.gitignore
.python-version
